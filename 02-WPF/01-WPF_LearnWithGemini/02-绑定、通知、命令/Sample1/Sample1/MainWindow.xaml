<Window x:Class="Sample1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sample1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="50">
            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
             Margin="0,0,0,10"/>

            <TextBlock Text="{Binding UserName}" 
               FontSize="20" FontWeight="Bold" Foreground="DarkBlue"/>

            <Button Content="点击更改" Command="{Binding ChangeNameCommand}" Margin="0,10,0,0"/>
            <Button Content="清空" Command="{Binding ClearNameCommand}" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
